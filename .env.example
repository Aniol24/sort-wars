ANTHROPIC_API_KEY=your_anthropic_api_key_here

# TikTok session (generated on first login via playwright)
TIKTOK_SESSION_FILE=./data/tiktok_session.json

# Paths (defaults work with docker-compose volumes)
DB_PATH=./data/algorithms.db
VIDEOS_OUTPUT_DIR=./output
LOGS_DIR=./logs

# Schedule: comma-separated HH:MM times (RPi local time)
SCHEDULE_TIMES=09:00,20:00
VIDEOS_PER_RUN=1
