ANTHROPIC_API_KEY=your_anthropic_api_key_here

# TikTok API credentials (from developers.tiktok.com → your app → Credentials)
TIKTOK_CLIENT_KEY=your_client_key_here
TIKTOK_CLIENT_SECRET=your_client_secret_here

# Paths (defaults work fine, no need to change)
DB_PATH=./data/algorithms.db
VIDEOS_OUTPUT_DIR=./output
LOGS_DIR=./logs

# Schedule: comma-separated HH:MM times (RPi local time)
SCHEDULE_TIMES=09:00,20:00
VIDEOS_PER_RUN=1
